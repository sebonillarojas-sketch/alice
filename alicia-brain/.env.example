# ── Core ──────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
PORT=3001

# ── DB ────────────────────────────────────────────────────────────────────────
DB_MODE=sqlite
SQLITE_PATH=./alicia.db

# ── ERP Backend ───────────────────────────────────────────────────────────────
ERP_URL=http://localhost:3002
ERP_API_KEY=alice-erp-dev-key

# ── WhatsApp (Meta) ───────────────────────────────────────────────────────────
WA_PHONE_NUMBER_ID=
WA_ACCESS_TOKEN=
WA_VERIFY_TOKEN=

# ── Twilio (sandbox WA) ───────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# ── Groq (transcripción audio) ────────────────────────────────────────────────
GROQ_API_KEY=

# ── Google (Calendar + Gmail) ─────────────────────────────────────────────────
# console.cloud.google.com → Calendar API + Gmail API → OAuth 2.0
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# ── Zoom ──────────────────────────────────────────────────────────────────────
# marketplace.zoom.us → Build App → Server-to-Server OAuth
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=

# ── Dropbox ───────────────────────────────────────────────────────────────────
# dropbox.com/developers → My Apps → Generate access token
DROPBOX_ACCESS_TOKEN=

# ── Tavily (web search) ───────────────────────────────────────────────────────
# tavily.com → gratis hasta 1000 req/mes
TAVILY_API_KEY=

# ── Teléfonos del equipo ──────────────────────────────────────────────────────
PHONE_SB=51999999999
PHONE_VD=51999999998
PHONE_JT=51999999997
PHONE_JM=51999999996
PHONE_AA=51999999995
PHONE_AC=51999999994
PHONE_JMG=51999999993
ALLOWED_USER_PHONES=51999999999,51999999998
